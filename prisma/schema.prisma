// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?  @db.Text
  access_token       String?  @db.Text
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?  @db.Text
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  sessions      Session[]

  password      String?   // null pour les comptes OAuth (Google, etc.)

  // --- OptiBot Core ---
  clientCount   Int       @default(0)
  isPro         Boolean   @default(false)
  role          String    @default("USER") // Global role: USER or ADMIN (System Admin)
  
  // --- Team ---
  teamId        String?
  team          Team?     @relation(fields: [teamId], references: [id])
  teamRole      String?   @default("MEMBER") // OWNER, ADMIN, MEMBER
  invitationsSent Invitation[]

  syncToken     String?   @unique @default(cuid())
  depotTokens   DepotToken[]

  passwordChangedAt DateTime?

  // --- Plan ---
  plan          String    @default("FREE") // FREE, SOLO, DUO

  // --- Stripe (Personal) ---
  stripeCustomerId       String?   @unique
  stripeSubscriptionId   String?   @unique

  metier        Metier?   // null = onboarding incomplet

  rechercheMasquee Boolean @default(false)

  createdAt     DateTime  @default(now())
  lastActiveAt  DateTime  @default(now())

  @@index([teamId])
  @@index([role])
  @@index([createdAt])
}

model Team {
  id            String    @id @default(cuid())
  name          String
  ownerId       String    // References User.id (logic enforced, not FK to avoid cycle/complexity initially, or we can make it FK)
  
  // --- Stripe (Team) ---
  stripeCustomerId       String?   @unique
  stripeSubscriptionId   String?   @unique
  plan                   String    @default("FREE") // FREE, PRO, ENTERPRISE

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  users         User[]
  invitations   Invitation[]

  @@index([ownerId])
}

model Invitation {
  id            String    @id @default(cuid())
  email         String
  token         String    @unique
  role          String    @default("MEMBER")
  expires       DateTime
  
  teamId        String
  team          Team      @relation(fields: [teamId], references: [id], onDelete: Cascade)
  
  inviterId     String
  inviter       User      @relation(fields: [inviterId], references: [id], onDelete: Cascade)

  @@unique([teamId, email])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model DepotToken {
  id          String   @id @default(cuid())
  token       String   @unique
  userId      String
  bienAdresse String
  message     String?
  expiresAt   DateTime
  used        Boolean  @default(false)
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  fichiers    FichierChiffre[]
}

model FichierChiffre {
  id          String   @id @default(cuid())
  tokenId     String
  nomOriginal String
  nomRenomme  String
  contenu     Bytes
  iv          String
  taille      Int
  uploadedAt  DateTime @default(now())
  token       DepotToken @relation(fields: [tokenId], references: [id], onDelete: Cascade)
}

// ─── Métier Utilisateur ───────────────────────────────────────────────────────

enum Metier {
  PROPRIETAIRE
  AGENCE
  GESTIONNAIRE
}

// ─── Relances Candidat ────────────────────────────────────────────────────────

enum StatutRelance {
  EN_ATTENTE
  RELANCE_1
  RELANCE_2
  RELANCE_3
  COMPLET
  ABANDONNE
}

model RelanceCandidat {
  id              String        @id @default(cuid())
  depotToken      String        // référence au token de dépôt
  userId          String        // gestionnaire propriétaire
  email           String
  telephone       String?
  sequence        Int           @default(0)
  statut          StatutRelance @default(EN_ATTENTE)
  derniereRelance DateTime?
  createdAt       DateTime      @default(now())

  @@index([userId])
  @@index([depotToken])
}

// ─── Vie du Bail ─────────────────────────────────────────────────────────────

enum StatutBail {
  ACTIF
  PREAVIS
  TERMINE
  RENOUVELE
}

enum TypeAlerte {
  REVISION_LOYER
  RENOUVELLEMENT
  CONGE_BAILLEUR
  DIAGNOSTIC_DPE
  DIAGNOSTIC_ELEC
  ASSURANCE_PNO
}

model BailActif {
  id                  String      @id @default(cuid())
  userId              String
  bienId              String
  descriptionLot      String?     // ex: "Chambre 1", "Studio RDC", "Appartement T2"
  locataireNom        String
  locataireEmail      String
  dateSignature       DateTime
  dateDebut           DateTime
  dateFin             DateTime?
  dureePreavisMois    Int         @default(3)
  loyerMensuel        Float
  chargesMensuelles   Float       @default(0)
  indiceRevision      String      @default("IRL")
  dateProchRevision   DateTime
  dateFinDiagnostics  DateTime?
  statut              StatutBail  @default(ACTIF)
  colocataires        Json?       @default("[]")
  garants             Json?       @default("[]")
  dateSortie          DateTime?
  motifSortie         String?
  createdAt           DateTime    @default(now())
  alertes             AlerteBail[]
  quittancesAuto      QuittanceAuto[]

  @@index([userId])
  @@index([bienId])
}

model QuittanceAuto {
  id             String    @id @default(cuid())
  bailId         String
  mois           String    // "2026-03"
  numero         String?   @unique // QUI-YYYY-NNNN
  envoyeeLe      DateTime  @default(now())
  emailLocataire String
  emailProprio   String
  bail           BailActif @relation(fields: [bailId], references: [id], onDelete: Cascade)

  @@unique([bailId, mois])
  @@index([bailId])
}

model AlerteBail {
  id              String     @id @default(cuid())
  bailId          String
  type            TypeAlerte
  dateEcheance    DateTime
  traitee         Boolean    @default(false)
  notifJ30Envoyee Boolean    @default(false)
  notifJ7Envoyee  Boolean    @default(false)
  createdAt       DateTime   @default(now())
  bail            BailActif  @relation(fields: [bailId], references: [id], onDelete: Cascade)

  @@index([bailId])
  @@index([dateEcheance])
}

// ─── État des Lieux ──────────────────────────────────────────────────────────

enum TypeEDL {
  ENTREE
  SORTIE
}

model EtatDesLieux {
  id                   String   @id @default(cuid())
  userId               String
  bienId               String
  bailId               String?
  type                 TypeEDL
  date                 DateTime
  pieces               Json
  compteurs            Json
  cles                 Json
  signatureLocataire   String?
  signatureBailleur    String?
  pdfUrl               String?
  createdAt            DateTime @default(now())

  @@index([userId])
  @@index([bienId])
}

// ─── Espace Locataire ────────────────────────────────────────────────────────

enum TypeDemande {
  DOCUMENT
  TRAVAUX
  QUESTION
  CONGE
}

enum StatutDemande {
  NOUVEAU
  EN_COURS
  RESOLU
}

model EspaceLocataire {
  id        String   @id @default(cuid())
  userId    String
  bailId    String   @unique
  token     String   @unique @default(cuid())
  actif     Boolean  @default(true)
  expiresAt DateTime
  createdAt DateTime @default(now())
  demandes  DemandeLocataire[]

  @@index([userId])
}

model DemandeLocataire {
  id        String        @id @default(cuid())
  espaceId  String
  type      TypeDemande
  message   String
  statut    StatutDemande @default(NOUVEAU)
  reponse   String?
  createdAt DateTime      @default(now())
  espace    EspaceLocataire @relation(fields: [espaceId], references: [id], onDelete: Cascade)

  @@index([espaceId])
}

// ─── Biens (migration depuis IndexedDB) ─────────────────────────────────

model Bien {
  id              String   @id @default(cuid())
  userId          String
  adresse         String
  loyer           Float
  charges         Float    @default(0)
  typeBail        TypeBail @default(HABITATION_VIDE)
  locataireNom    String?
  locatairePrenom String?
  dateEntree      DateTime?
  dateFin         DateTime?
  preavisMois     Int?
  dateRevision    DateTime?
  indiceReference String?
  diagnostics     Json?    @default("[]")
  statut          String?  @default("vacant")
  annexes         Json?    @default("[]")
  createdAt       DateTime @default(now())

  @@index([userId])
}

// ─── Paiements (migration depuis IndexedDB) ─────────────────────────────

model PaiementBien {
  id              String    @id @default(cuid())
  userId          String
  bienId          String
  locataireNom    String
  locatairePrenom String?
  locataireEmail  String?
  loyerCC         Float
  dateAttendue    DateTime
  dateReelle      DateTime?
  statut          String    @default("attendu")
  montantRecu     Float?
  mois            String
  notes           String?
  relances        Json      @default("[]")
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([userId])
  @@index([bienId])
  @@index([mois])
}

// ─── Candidatures (migration depuis IndexedDB) ──────────────────────────

model CandidatureLocal {
  id             String   @id @default(cuid())
  userId         String
  bienId         String
  statut         String   @default("en_attente")
  dossier        Json     @default("{}")
  bailScore      Float?
  scoreGrade     String?
  eligibleVisale Boolean?
  alertesFraude  Int?
  aGarant        Boolean  @default(false)
  dossierGarant  Json?
  completude     Json?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([userId])
  @@index([bienId])
}

// ─── Bail Professionnel ───────────────────────────────────────────────────────

enum TypeBail {
  HABITATION_VIDE
  HABITATION_MEUBLE
  PROFESSIONNEL
}

enum IndiceProRevision {
  ILC
  ILAT
  ICC
  LIBRE
}

model ContratPro {
  id                String            @id @default(cuid())
  bienId            String
  locataireId       String
  dateDebut         DateTime
  dureeAns          Int               @default(6)
  loyerHT           Float
  chargesHT         Float             @default(0)
  tvaApplicable     Boolean           @default(false)
  indiceRevision    IndiceProRevision @default(ILAT)
  depotGarantie     Float             @default(0)
  preavisLocataire  Int               @default(6)
  clausesSpeciales  String?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  @@index([bienId])
}

// ─── Gestion Travaux ────────────────────────────────────────────────────────

enum StatutTravaux {
  A_FAIRE
  EN_COURS
  TERMINE
  ANNULE
}

enum CategorieTravaux {
  PLOMBERIE
  ELECTRICITE
  CHAUFFAGE
  ISOLATION
  TOITURE
  MENUISERIE
  PEINTURE
  CARRELAGE
  SALLE_DE_BAIN
  CUISINE
  EXTERIEUR
  AUTRE
}

model Travaux {
  id           String            @id @default(cuid())
  userId       String
  bienId       String
  titre        String
  description  String?
  statut       StatutTravaux     @default(A_FAIRE)
  categorie    CategorieTravaux
  montantDevis Float?
  montantReel  Float?
  dateDebut    DateTime?
  dateFin      DateTime?
  artisanNom   String?
  artisanTel   String?
  artisanEmail String?
  deductible   Boolean           @default(true)
  notes        String?
  documents    TravauxDocument[]
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  @@index([userId])
  @@index([bienId])
}

model TravauxDocument {
  id        String   @id @default(cuid())
  travauxId String
  nom       String
  type      String
  url       String
  taille    Int?
  createdAt DateTime @default(now())
  travaux   Travaux  @relation(fields: [travauxId], references: [id], onDelete: Cascade)

  @@index([travauxId])
}

// ─── Copropriété ────────────────────────────────────────────────────────────

enum TypeDocCopro {
  APPEL_CHARGES
  RELEVE_DEPENSES
  PV_ASSEMBLEE
  BUDGET_PREVISIONNEL
  AUTRE
}

model DocumentCopro {
  id          String       @id @default(cuid())
  userId      String
  bienId      String
  nom         String
  type        TypeDocCopro
  annee       Int
  trimestre   Int?
  contenu     String
  taille      Int?
  analyseJson String?
  createdAt   DateTime     @default(now())

  @@index([userId])
  @@index([bienId])
}
