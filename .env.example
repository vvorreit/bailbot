# BailBot — Variables d'environnement
# Copiez ce fichier en .env.local et remplissez les valeurs

# Base de données
DATABASE_URL=postgresql://user:password@localhost:5432/bailbot

# NextAuth
NEXTAUTH_URL=http://localhost:3011
NEXTAUTH_SECRET=your-secret-here

# Stripe
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...

# Prix Stripe (en euros)
STRIPE_PRICE_ESSENTIEL_AMOUNT=39
STRIPE_PRICE_SERENITE_AMOUNT=59
STRIPE_PRICE_PORTFOLIO_AMOUNT=89

# Stripe Price IDs
STRIPE_PRICE_ESSENTIEL=price_...
STRIPE_PRICE_SERENITE=price_...
STRIPE_PRICE_PORTFOLIO=price_...

# Email (Resend)
RESEND_API_KEY=re_...
EMAIL_FROM=noreply@bailbot.fr

# Google Analytics (optionnel)
NEXT_PUBLIC_GA_ID=G-...

# Upstash Redis (rate limiting, optionnel)
UPSTASH_REDIS_REST_URL=https://...
UPSTASH_REDIS_REST_TOKEN=...

# ─── Plans B2C Particulier ──────────────────────────────────────────────────
STRIPE_PRICE_OCCASION=  # 4,90€ one-time (payment_intent)
STRIPE_PRICE_PARTICULIER=  # 9,90€/mois recurring
STRIPE_PRICE_PARTICULIER_AMOUNT=9.90
STRIPE_PRICE_OCCASION_AMOUNT=4.90
NEXT_PUBLIC_FREE_LIMIT=3  # 3 dossiers gratuits avant paiement

# ─── DossierFacile Connect (OAuth2 SSO) ─────────────────────────────────────
# Obtenez vos credentials : contact@dossierfacile.logement.gouv.fr
# Doc : https://dossierfacile.logement.gouv.fr/partenaires
# Laisser vide pour désactiver le bouton DossierFacile Connect
DOSSIERFACILE_CLIENT_ID=
DOSSIERFACILE_CLIENT_SECRET=
DOSSIERFACILE_REDIRECT_URI=https://bailbot.fr/api/auth/dossierfacile/callback
# Pour la preprod, utiliser : https://api-preprod.dossierfacile.fr
DOSSIERFACILE_API_URL=https://api.dossierfacile.fr
DOSSIERFACILE_SSO_URL=https://sso.dossierfacile.logement.gouv.fr

# ─── Web Push (VAPID) ───────────────────────────────────────────────────────
# Générer avec : npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# ─── Chiffrement RGPD ──────────────────────────────────────────────────────
# Clé AES-256 pour chiffrer les données sensibles (IBAN, etc.)
# Générer avec : openssl rand -hex 32
ENCRYPTION_KEY=

# ─── Yousign (Signature eIDAS) ────────────────────────────────────────────
# API key depuis le dashboard Yousign
YOUSIGN_API_KEY=
# "sandbox" ou "production"
YOUSIGN_ENV=sandbox
# Secret pour vérifier les webhooks Yousign (HMAC SHA-256)
YOUSIGN_WEBHOOK_SECRET=

# ─── Admin ───────────────────────────────────────────────────────────────
ADMIN_EMAIL=contact@optibot.fr

# ─── Cron Jobs ──────────────────────────────────────────────────────────────
# Secret pour protéger les endpoints cron (/api/cron/*)
# Générer avec : openssl rand -hex 16
CRON_SECRET=

# ─── Feature Flags (crons critiques) ─────────────────────────────────────
# true = activé (défaut si non défini), false = désactivé
FEATURE_QUITTANCES_AUTO=true
FEATURE_RAPPELS_IMPAYES=true
FEATURE_INDEXATION_IRL=true
FEATURE_RGPD_PURGE=true
